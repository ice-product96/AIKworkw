# Copy to .env.prod and set real values before production deploy.
# cp .env.prod.example .env.prod

POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-use-openssl-rand-hex-32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# LAN: replace 192.168.x.x with your server IP (hostname -I)
CORS_ORIGINS=http://192.168.x.x:8011,http://127.0.0.1:8011

# 0.0.0.0 = доступ из локальной сети; 127.0.0.1 = только с самого сервера
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=8011
